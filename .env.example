# Optional: enables the LLM deliberation layer of the committee engine.
# Without a key the app runs on the deterministic rule engine alone.
# The LLM only deepens per-member qualitative text and may only cite rows
# from the evidence table; ratings/vetoes/allocation stay rule-based.
ANTHROPIC_API_KEY=

# Optional: override the model used for deliberation (default: claude-opus-4-8)
COMMITTEE_LLM_MODEL=
